@page
@model MiniHR.Pages.Employees.DetailsModel

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<div>
    <h4>직원 세부 정보</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-4">
            @Html.DisplayNameFor(model => model.Employee.EmployeeNumber)
        </dt>
        <dd class="col-sm-8">
            @Html.DisplayFor(model => model.Employee.EmployeeNumber)
        </dd>
        <dt class="col-sm-4">
            @Html.DisplayNameFor(model => model.Employee.Name)
        </dt>
        <dd class="col-sm-8">
            @Html.DisplayFor(model => model.Employee.Name)
        </dd>
        <dt class="col-sm-4">
            @Html.DisplayNameFor(model => model.Employee.Department)
        </dt>
        <dd class="col-sm-8">
            @Html.DisplayFor(model => model.Employee.Department)
        </dd>
        <dt class="col-sm-4">
            @Html.DisplayNameFor(model => model.Employee.HireDate)
        </dt>
        <dd class="col-sm-8">
            @Html.DisplayFor(model => model.Employee.HireDate)
        </dd>
        <dt class="col-sm-4">
            @Html.DisplayNameFor(model => model.Employee.AnnualSalary)
        </dt>
        <dd class="col-sm-8">
            @Html.DisplayFor(model => model.Employee.AnnualSalary)
        </dd>
    </dl>
    </div>

    <h4>연차 관리 현황</h4>
    <hr />
    <div class="row mb-4">
        <div class="col-sm-12">
            <div class="card">
                <div class="card-body">
                    <div class="row text-center mb-3">
                        <div class="col-4">
                            <h5>총 연차</h5>
                            <p class="display-6 text-primary">@Model.TotalAnnualLeave</p>
                        </div>
                        <div class="col-4">
                            <h5>사용 연차</h5>
                            <p class="display-6 text-danger">@Model.UsedAnnualLeave</p>
                        </div>
                        <div class="col-4">
                            <h5>잔여 연차</h5>
                            <p class="display-6 text-success">@Model.RemainingAnnualLeave</p>
                        </div>
                    </div>
    
                    @{
                        var usagePercent = Model.TotalAnnualLeave > 0 
                            ? (Model.UsedAnnualLeave / Model.TotalAnnualLeave) * 100 
                            : 0;
                    }
                    <div class="progress" style="height: 25px;">
                        <div class="progress-bar bg-info" role="progressbar" 
                             style="width: @(usagePercent)%;" 
                             aria-valuenow="@usagePercent" aria-valuemin="0" aria-valuemax="100">
                            @usagePercent.ToString("F1")% 사용됨
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div>
    <h4>금일의 근태 현황</h4>
    <hr />
    @if (Model.TodayAttendance != null)
    {
        <dl class="row">
            <dt class="col-sm-4">금일 출근 시간</dt>
            <dd class="col-sm-8">@Model.TodayAttendance.CheckInTime.ToString("HH:mm:ss")</dd>

            <dt class="col-sm-4">금일 퇴근 시간</dt>
            <dd class="col-sm-8">
                @(Model.TodayAttendance.CheckOutTime?.ToString("HH:mm:ss") ?? "업무 중")
            </dd>
        </dl>
    }
    else
    {
        <p class="text-muted">오늘 등록된 출근 기록이 없습니다.</p>
    }
        <dl class="row">
            <dt class="col-sm-4">이번 달 총 출근 일수</dt>
            <dd class="col-sm-8">
                @(Model.TotalAttandanceCount + " 일")
            </dd>
        </dl>


    <h4>전체 근태 현황</h4>
    <hr />
    @if (Model.Attendances != null && Model.Attendances.Count > 0)
    {
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>날짜</th>
                    <th>출근 시간</th>
                    <th>퇴근 시간</th>
                    <th>상태</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Attendances)
                {
                    <tr>
                        <td>@item.WorkDate.ToString("yyyy-MM-dd")</td>
                        <td>@item.CheckInTime.ToString("HH:mm:ss")</td>
                        <td>@(item.CheckOutTime?.ToString("HH:mm:ss") ?? "-")</td>
                        <td>
                            <span class="badge @(item.CheckOutTime == null ? "bg-warning" : "bg-success")">
                                @(item.CheckOutTime == null ? "근무 중" : "퇴근")
                            </span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    
        <nav>
            <ul class="pagination">
                @for (var i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a asp-page="./Details" 
                           asp-route-id="@Model.Employee.EmployeeNumber" 
                           asp-route-CurrentPage="@i" 
                           class="page-link">@i</a>
                    </li>
                }
            </ul>
        </nav>
    }
    else
    {
        <p class="text-muted">기록된 근태 현황이 없습니다.</p>
    }

</div>
<div>
    <a asp-page="./Edit" asp-route-id="@Model.Employee.Id">Edit</a> |
    <a asp-page="./Index">Back to List</a>
</div>
