@page
@model MiniHR.Pages.Employees.IndexModel
@using MiniHR.Models
@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<dl class="row">
            <dt class="col-sm-12">[금일 출근자 : @Model.TotalCheckedIn.ToString() 명 / 미출근 : @Model.TotalNotCheckedIn.ToString() 명]</dt>
        </dl>

@if (User.IsInRole(Employee.RoleType.Admin.ToString()))
{
    <p>
        <a asp-page="Create" class="btn btn-primary">사원 등록(관리자)</a>
    </p>
}

<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.EmployeeList[0].Name)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.EmployeeList[0].Department)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.EmployeeList[0].HireDate)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.EmployeeList[0].AnnualSalary)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model.EmployeeList) {
    var todayLog = Model.AttendanceDict.GetValueOrDefault(item.Id);
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Name)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Department)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.HireDate)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.AnnualSalary)
            </td>
            <td>
            @if (User.IsInRole(Employee.RoleType.Admin.ToString()) || 
                (User.Identity != null && User.Identity.Name == item.EmployeeNumber))
            {
                @if (todayLog == null) //출근 전
                {
                    <form method="post" asp-page-handler="CheckIn" asp-route-EmployeeId="@item.EmployeeNumber" style="display:inline;">
                        <button type="submit" class="btn btn-sm btn-success">출근</button>
                    </form>
                }
                else if (todayLog.CheckOutTime == null) //출근 O , 퇴근 전
                {
                    <form method="post" asp-page-handler="CheckOut" asp-route-EmployeeId="@item.EmployeeNumber" style="display:inline;">
                        <button type="submit" class="btn btn-sm btn-danger">퇴근</button>
                    </form>
                }
                else
                {
                    <span class="badge bg-secondary">업무 종료(퇴근 완료)</span>
                }
            }
            </td>
            <td>
            @if (User.IsInRole(Employee.RoleType.Admin.ToString())) 
            {
                <a asp-page="./Edit" asp-route-id="@item.EmployeeNumber">수정(관리자)</a> @:|
                <a asp-page="./Details" asp-route-id="@item.EmployeeNumber">세부 정보</a> @:|
                <a asp-page="./Delete" asp-route-id="@item.EmployeeNumber">데이터 삭제</a>
            }
            else if (User.Identity != null && User.Identity.Name == item.EmployeeNumber) 
            {
                <a asp-page="./Edit" asp-route-id="@item.EmployeeNumber">내 정보 수정</a> @:|
                <a asp-page="./Details" asp-route-id="@item.EmployeeNumber">세부 정보</a>
            }
            </td>
        </tr>
}
    </tbody>
</table>
