@page
@model MiniHR.Pages.Employees.IndexModel
@using MiniHR.Models
@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<dl class="row">
            <dt class="col-sm-12">[금일 출근자 : @Model.TotalCheckedIn.ToString() 명 / 미출근 : @(Model.TotalCount - Model.TotalCheckedIn) 명 / 전체 직원 : @Model.TotalCount.ToString() 명]</dt>
        </dl>

<form method="get" class="mb-3">
    <div class="input-group" style="max-width: 400px;">
        <input type="text" name="SearchString" value="@Model.SearchString" 
               class="form-control" placeholder="이름 또는 부서 검색" />
        <button type="submit" class="btn btn-outline-primary">검색</button>
        
        @if (!string.IsNullOrEmpty(Model.SearchString))
        {
            <a asp-page="./Index" class="btn btn-outline-secondary">초기화</a>
        }
    </div>
</form>

@if (User.IsInRole(Employee.RoleType.Admin.ToString()))
{
    <p>
        <a asp-page="Create" class="btn btn-primary">사원 등록</a>
    </p>
}

<table class="table table-hover">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(model => model.EmployeeList[0].EmployeeNumber)</th>
            <th>@Html.DisplayNameFor(model => model.EmployeeList[0].Name)</th>
            <th>@Html.DisplayNameFor(model => model.EmployeeList[0].Department)</th>
            <th>@Html.DisplayNameFor(model => model.EmployeeList[0].HireDate)</th>
            <th>연차 현황 (잔여/총)</th> <th>@Html.DisplayNameFor(model => model.EmployeeList[0].AnnualSalary)</th>
            <th>근태</th>
            <th>관리</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.EmployeeList)
        {
            var todayLog = Model.AttendanceDict.GetValueOrDefault(item.EmployeeNumber);
            
            var usedLeave = Model.LeaveUsageDict.GetValueOrDefault(item.EmployeeNumber, 0m);
            var totalLeave = item.GetTotalAnnualLeave(DateTime.Today);
            var remainingLeave = totalLeave - usedLeave;

            <tr>
                <td>@Html.DisplayFor(modelItem => item.EmployeeNumber)</td>
                <td>@Html.DisplayFor(modelItem => item.Name)</td>
                <td>@Html.DisplayFor(modelItem => item.Department)</td>
                <td>@item.HireDate.ToString("yyyy-MM-dd")</td>
                
                <td>
                    @if (User.IsInRole(Employee.RoleType.Admin.ToString()) || (User.Identity?.Name == item.EmployeeNumber))
                    {
                    <span class="badge @(remainingLeave > 0 ? "bg-primary" : "bg-danger")">
                        @remainingLeave / @totalLeave
                    </span>
                    }
                    else
                    {
                        <span class="text-muted">비공개</span>
                    }
                </td>

                <td>
                    @if (User.IsInRole(Employee.RoleType.Admin.ToString()) || (User.Identity?.Name == item.EmployeeNumber))
                    {
                        @item.AnnualSalary.ToString("N0") @:원
                    }
                    else
                    {
                        <span class="text-muted">비공개</span>
                    }
                </td>

                <td>
                    @if (User.IsInRole(Employee.RoleType.Admin.ToString()) || (User.Identity?.Name == item.EmployeeNumber))
                    {
                        @if (todayLog == null)
                        {
                            <form method="post" asp-page-handler="CheckIn" asp-route-employeeNumber="@item.EmployeeNumber" style="display:inline;">
                                <button type="submit" class="btn btn-sm btn-success">출근</button>
                            </form>
                        }
                        else if (todayLog.CheckOutTime == null)
                        {
                            <form method="post" asp-page-handler="CheckOut" asp-route-employeeNumber="@item.EmployeeNumber" style="display:inline;">
                                <button type="submit" class="btn btn-sm btn-danger">퇴근</button>
                            </form>
                        }
                        else
                        {
                            <span class="badge bg-secondary">퇴근 완료</span>
                        }
                    }
                </td>

                <td>
                    @if (User.IsInRole(Employee.RoleType.Admin.ToString()))
                    {
                        <a asp-page="./Edit" asp-route-id="@item.EmployeeNumber" class="btn btn-sm btn-outline-secondary">수정</a>
                        <a asp-page="./Details" asp-route-id="@item.EmployeeNumber" class="btn btn-sm btn-outline-info">정보</a>
                        <a asp-page="./Delete" asp-route-id="@item.EmployeeNumber" class="btn btn-sm btn-outline-danger">삭제</a>
                    }
                    else if (User.Identity?.Name == item.EmployeeNumber)
                    {
                        <a asp-page="./Edit" asp-route-id="@item.EmployeeNumber" class="btn btn-sm btn-outline-secondary">내 정보 수정</a>
                        <a asp-page="./Details" asp-route-id="@item.EmployeeNumber" class="btn btn-sm btn-outline-info">세부 정보</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

<nav>
    <ul class="pagination">
        @for (var i = 1; i <= Model.TotalPages; i++)
        {
            <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                <a asp-page="./Index" 
                   asp-route-CurrentPage="@i" 
                   asp-route-SearchString="@Model.SearchString" 
                   class="page-link">@i</a>
            </li>
        }
    </ul>
</nav>