@page
@model MiniHR.Pages.Employees.IndexModel

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<dl class="row">
            <dt class="col-sm-12">[금일 출근자 : @Model.TotalCheckedIn.ToString() 명 / 미출근 : @Model.TotalNotCheckedIn.ToString() 명]</dt>
        </dl>

<p>
    <a asp-page="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Employee[0].Name)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Employee[0].Department)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Employee[0].HireDate)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Employee[0].AnnualSalary)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model.Employee) {
    var todayLog = Model.AttendanceDict.GetValueOrDefault(item.Id);
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Name)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Department)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.HireDate)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.AnnualSalary)
            </td>
            <td>
                @if (todayLog == null) //출근 전
                {
                    <form method="post" asp-page-handler="CheckIn" asp-route-id="@item.Id" style="display:inline;">
                        <button type="submit" class="btn btn-sm btn-success">출근</button>
                    </form>
                }
                else if (todayLog.CheckOutTime == null) //출근 O , 퇴근 전
                {                    
                    <form method="post" asp-page-handler="CheckOut" asp-route-id="@item.Id" style="display:inline;">
                        <button type="submit" class="btn btn-sm btn-danger">퇴근</button>
                    </form>
                }
                else 
                {
                    <span class="badge bg-secondary">업무 종료(퇴근 완료)</span>
                }
            </td>
            <td>
                <a asp-page="./Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-page="./Details" asp-route-id="@item.Id">Details</a> |
                <a asp-page="./Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
