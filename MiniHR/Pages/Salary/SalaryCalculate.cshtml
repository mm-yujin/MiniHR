@page
@model MiniHR.Pages.Salary.SalaryCalculateModel

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>@DateTime.Today.ToString("yyyy년 MM월") 급여 관리</h2>
    <a asp-page="./SalarySetting" class="btn btn-outline-secondary">요율 설정 변경</a>
</div>

<div class="card border-primary mb-5">
    <div class="card-body text-center">
        <p class="card-text">설정된 요율에 따라 전체 사원의 급여를 계산합니다. <strong>이미 생성된 데이터가 있다면 삭제 후 재계산됩니다.</strong></p>
        <form method="post" asp-page-handler="GenerateAll">
            <button type="submit" class="btn btn-primary btn-lg px-5">
                @DateTime.Today.Month 월 급여 생성/재계산 실행
            </button>
        </form>
    </div>
</div>

<h3>급여 산출 결과 (@Model.CompletedSalaryLogs.Count 명)</h3>
<table class="table table-hover border">
    <thead class="table-dark">
        <tr>
            <th>사번</th>
            <th>이름</th>
            <th>기본급</th>
            <th>기본급외</th>
            <th>공제합계</th>
            <th>실수령액</th>
            <th>관리</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var log in Model.CompletedSalaryLogs)
        {
            <tr>
                <td>@log.EmployeeNumber</td>
                <td>@log.Employee?.Name</td>
                <td>@log.BaseSalary.ToString("N0")원</td>
                <td>@log.MealAllowance.ToString("N0")원</td>
                <td>@((log.NationalPension + log.HealthInsurance + log.EmploymentInsurance + log.LongTermCare + log.IncomeTax).ToString("N0"))원</td>
                <td class="text-primary fw-bold">@log.NetPay.ToString("N0")원</td>
                <td>
                    <a asp-page="./SalaryDetail" 
                        asp-route-empNo="@log.EmployeeNumber" asp-route-yearMonth="@log.YearMonth" 
                        class="btn btn-sm btn-outline-info"> <i class="bi bi-file-earmark-text"></i> 명세서 보기</a>
                </td>
            </tr>
        }
    </tbody>
</table>